# Salin file ini menjadi .env dan isi semua nilainya

# Koneksi Neon PostgreSQL
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# JWT Secret untuk masing-masing role (harus berbeda satu sama lain)
JWT_SECRET_SUPERADMIN=sa_rahasia_ganti_ini_min32karakter_xxxx
JWT_SECRET_ADMIN=adm_rahasia_ganti_ini_min32karakter_xxxx
JWT_SECRET_ANGGOTA=ang_rahasia_ganti_ini_min32karakter_xxxx

# Key untuk setup database pertama kali (bisa diubah sesukanya)
SETUP_KEY=HIMTI2025SETUP

PORT=3000
