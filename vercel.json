{
  "version": 2,
  "builds": [
    { "src": "server.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/server.js" },
    { "src": "/anggota/(.*)", "dest": "/public/anggota/$1" },
    { "src": "/admin/(.*)", "dest": "/public/admin/$1" },
    { "src": "/superadmin/(.*)", "dest": "/public/superadmin/$1" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
